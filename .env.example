# Copy this to .env.local (or .env) and fill with real values.
# Do NOT commit real secrets to the repository.

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=public-anon-key-placeholder
# Use the service role key ONLY for deployment/migration workflows that run in CI with protected secrets.
SUPABASE_SERVICE_ROLE_KEY=service-role-key-placeholder
SUPABASE_PROJECT_REF=your-project-ref

# Optional: local dev DB connection if using docker-compose or direct Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/monster_command

# App-specific (example)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
